# Configuración de PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbgct
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# Configuración de Django
DJANGO_SECRET_KEY=tu-clave-secreta-aqui-cambia-en-produccion
DEBUG=True

# Configuración de Email
# Para desarrollo, usa consola (se muestra en terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Para producción con Gmail u otro SMTP, descomenta y configura:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu_email@gmail.com
# EMAIL_HOST_PASSWORD=tu_password_o_app_key
# DEFAULT_FROM_EMAIL=RBG CT <no-reply@rbgct.com>

# URL del Frontend para links en emails
FRONTEND_URL=http://localhost:5173

# Configuración Gmail SMTP
# 1. Usa tu email de Gmail
# 2. Genera una "App Password" en: https://myaccount.google.com/apppasswords
#    - Selecciona "Otra" y ponle nombre "RBG CT"
#    - Copia la contraseña de 16 caracteres (sin espacios)
# 3. Pega esa contraseña aquí (NO uses tu password normal de Gmail)
EMAIL_HOST_USER=tu_email@gmail.com
EMAIL_HOST_PASSWORD=xxxx_xxxx_xxxx_xxxx
DEFAULT_FROM_EMAIL=RBG CT <tu_email@gmail.com>
