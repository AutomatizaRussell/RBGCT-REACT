# ============================================================================
# APPWRITE STORAGE (almacenamiento de archivos en la nube)
# ============================================================================
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=tu_project_id
APPWRITE_BUCKET_ID=tu_bucket_id
APPWRITE_API_KEY=tu_api_key_secreto

# ============================================================================
# BASE DE DATOS (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbgct
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ============================================================================
# DJANGO
# ============================================================================
# IMPORTANTE: Genera una nueva clave con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=tu-clave-secreta-aqui-cambia-en-produccion
DEBUG=False

# Para desarrollo local, cambia a True y usa console email
# DEBUG=True

# ============================================================================
# EMAIL (Resend - Producción) O Console (Desarrollo)
# ============================================================================
# OPCIÓN 1: DESARROLLO (muestra emails en terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# OPCIÓN 2: PRODUCCIÓN (Resend.com)
# EMAIL_BACKEND=anymail.backends.resend.EmailBackend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=RBG CT <noreply@rbgct.com>

# ============================================================================
# FRONTEND URL (para links en emails y CORS)
# ============================================================================
FRONTEND_URL=http://localhost:5173

# Desarrollo:
# FRONTEND_URL=http://localhost:5173

# Producción:
# FRONTEND_URL=https://tu-dominio.com

# ============================================================================
# N8N (Automatización de Workflows)
# ============================================================================
# Obtén la URL del webhook desde tu instancia de n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook/tu-webhook-name
N8N_WEBHOOK_API_KEY=tu-api-key-n8n

# ============================================================================
# CORS (Control de acceso entre dominios)
# ============================================================================
# Desarrollo (permite todo):
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Producción:
# CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ============================================================================
# SEGURIDAD (HTTPS, HSTS, etc.)
# ============================================================================
# En producción, asegúrate de:
# - SECURE_SSL_REDIRECT=True
# - SECURE_HSTS_SECONDS=31536000
# - SECURE_HSTS_INCLUDE_SUBDOMAINS=True


APPWRITE_API_KEY=**************************
APPWRITE_PROJECT_ID=***************************
APPWRITE_BUCKET_ID=************************************
APPWRITE_ENDPOINT=******************************