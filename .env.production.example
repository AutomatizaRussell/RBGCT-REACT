# ─────────────────────────────────────────────────────────────
#  PLANTILLA DE PRODUCCIÓN — rbgct.cloud
#  Copiar a backend/.env en el VPS y completar los valores
#  NUNCA commitear este archivo con valores reales
# ─────────────────────────────────────────────────────────────

# ─── BASE DE DATOS ────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=rbgct
DB_USER=rbgct
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ─── DJANGO ───────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CAMBIAR_POR_CLAVE_GENERADA
DEBUG=False
ALLOWED_HOSTS=rbgct.cloud,www.rbgct.cloud
CSRF_TRUSTED_ORIGINS=https://rbgct.cloud,https://www.rbgct.cloud
CORS_ALLOWED_ORIGINS=https://rbgct.cloud,https://www.rbgct.cloud
FRONTEND_URL=https://rbgct.cloud

# ─── SUPERADMIN (primer arranque, se crea automáticamente) ────
SUPERADMIN_EMAIL=admin@rbgct.cloud
SUPERADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ─── EMAIL SMTP ───────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=CAMBIAR_POR_EMAIL
EMAIL_HOST_PASSWORD=CAMBIAR_POR_APP_PASSWORD
DEFAULT_FROM_EMAIL=RG-conectar <no-reply@rbgct.cloud>

# ─── APPWRITE Storage ─────────────────────────────────────────
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=CAMBIAR
APPWRITE_BUCKET_ID=CAMBIAR
APPWRITE_API_KEY=CAMBIAR

# ─── n8n Webhooks ─────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.rbgct.cloud/webhook/rbgct-nuevo-usuario
N8N_WEBHOOK_API_KEY=CAMBIAR

# ─── Cache compartida entre workers (recomendado) ─────────────
# file: usa disco local compartido entre workers del mismo contenedor.
# redis: requiere servicio redis y paquete redis instalado.
CACHE_BACKEND=file
CACHE_DIR=/tmp/django_cache
# REDIS_URL=redis://redis:6379/1

# ─── Gunicorn (backend) ───────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ─── Resend ───────────────────────────────────────────────────
RESEND_API_KEY=CAMBIAR
